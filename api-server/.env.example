# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default)
DB_PATH=./data/project-claw.db
DB_TYPE=sqlite

# PostgreSQL (set DB_TYPE=postgresql to enable)
# DATABASE_URL=postgres://projectclaw:changeme@localhost:5432/project_claw
# DB_USER=projectclaw
# DB_PASSWORD=changeme
# DB_NAME=project_claw
# DB_HOST=localhost
# DB_PORT=5432
#
# To migrate from SQLite to PostgreSQL:
#   1. Start PostgreSQL:  docker compose --profile postgres up -d db
#   2. Run migration:     DATABASE_URL=postgres://projectclaw:changeme@localhost:5432/project_claw npm run migrate:pg
#   3. Update .env:       DB_TYPE=postgresql + DATABASE_URL=...
#   4. Restart server:    npm run dev

# ── Authentication ────────────────────────────────────────────────────────────
# Required in production — generates warning if not set
# JWT_SECRET=your-secret-key-here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated origins. Defaults to localhost:5173,5174,3000 in development.
# Set to * for any origin (NOT recommended for production).
# CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# ── AI Execution ──────────────────────────────────────────────────────────────
# Required for real AI task execution via OpenRouter
# Without this key, all AI calls return simulated results
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── Feature Flags ─────────────────────────────────────────────────────────────
# All default to true. Set to 'false' to disable.
# ENABLE_WEBSOCKETS=true
# ENABLE_RATE_LIMITING=true
# ENABLE_REQUEST_LOGGING=true

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# RATE_LIMIT_MAX=100          # Max requests per window
# RATE_LIMIT_WINDOW=60000     # Window in milliseconds (default: 1 minute)

# ── Security ──────────────────────────────────────────────────────────────────
# BCRYPT_ROUNDS=12            # Password hashing rounds
# MAX_REQUEST_SIZE=1mb        # Maximum request body size

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=info              # pino log level (trace, debug, info, warn, error)

# ── Redis (optional — enables shared rate limiting, caching, WS pub/sub) ──────
# Required for horizontal scaling (multiple API instances)
# REDIS_URL=redis://localhost:6379

# ── Sentry Error Tracking (optional) ─────────────────────────────────────────
# SENTRY_DSN=https://your-key@sentry.io/project-id

# ── SSL/HTTPS (optional — for Traefik in docker-compose.prod.yml) ────────────
# ACME_EMAIL=admin@yourdomain.com
