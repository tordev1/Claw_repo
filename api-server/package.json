{
  "name": "project-claw-api",
  "version": "1.2.0",
  "description": "PROJECT-CLAW API Server - Real Cost Tracking, Chat & Agent Management",
  "main": "src/server.js",
  "scripts": {
    "start": "set NODE_ENV=production && node src/server.js",
    "dev": "set NODE_ENV=development && node --watch src/server.js",
    "seed": "node src/seed.js",
    "seed:full": "node seed-new.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "NODE_ENV=test node --test src/**/*.test.js",
    "test:integration": "NODE_ENV=test node --test tests/integration/**/*.test.js",
    "lint": "eslint src/",
    "migrate": "node scripts/migrate.js",
    "migrate:pg": "node scripts/migrate-to-postgres.js",
    "sync:costs": "node -e \"require('./src/database').initDatabase().then(() => require('./src/openrouter').syncOpenRouterUsage().then(console.log).catch(console.error))\""
  },
  "keywords": [
    "fastify",
    "sqlite",
    "postgresql",
    "api",
    "websocket"
  ],
  "author": "Donatello (TMNT Tech)",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/websocket": "^8.3.1",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.6.2",
    "fastify": "^4.28.1",
    "pg": "^8.13.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "pino-pretty": "^11.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
